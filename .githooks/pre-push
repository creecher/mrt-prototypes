#!/bin/sh
# Prints the push destination before Git contacts the remote.
# Enable once per clone: git config core.hooksPath .githooks
remote="${1:-?}"
url="${2:-?}"
printf '\n'
printf '━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n'
printf '  Push destination (personal): %s\n' "$url"
printf '  Remote name:                  %s\n' "$remote"
printf '━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n'
printf '\n'
